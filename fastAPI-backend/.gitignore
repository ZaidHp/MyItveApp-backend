# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest cache
.pytest_cache/

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env

# Logs and databases
*.log
*.sqlite3
*.db

# Uploaded files (user uploads)
uploads/

# Compiled Cython files
*.pyx.c
*.pyx.so

# Ignore Python bytecode and caches
*.pyc

# Temporary files
*.tmp
*.temp

# JetBrains IDE caches
.idea/

# Node
node_modules/

